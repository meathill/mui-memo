{
  "name": "@mui-memo/web",
  "version": "0.8.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port ${PORT:-3200}",
    "build": "pnpm -F @mui-memo/shared build && next build --webpack",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "icons:generate": "node ./scripts/generate-brand-icons.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:prompt-eval": "PROMPT_EVAL=1 vitest run src/lib/intent-prompt.eval.test.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "cf-build": "opennextjs-cloudflare build",
    "cf-preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.11.0",
    "@mui-memo/shared": "workspace:*",
    "@next/third-parties": "^16.2.10",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tidbcloud/serverless": "^0.3.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "openai": "^6.47.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.6",
    "mysql2": "^3.23.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
