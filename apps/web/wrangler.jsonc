{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mui-memo-web",
  "main": ".open-next/worker.js",
  "account_id": "fdc63eeea83ae8f5234357308b9a638b",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "placement": {
    "mode": "smart"
  },
  "r2_buckets": [
    {
      "binding": "AUDIO_BUCKET",
      "bucket_name": "roudan-io"
    }
  ],
  "vars": {
    "NEXT_PUBLIC_ASSETS_URL": "https://ii.meathill.com",
    "NEXT_PUBLIC_SITE_URL": "https://muimemo.meathill.com",
    "BETTER_AUTH_URL": "https://muimemo.meathill.com",
    "CF_ACCOUNT_ID": "fdc63eeea83ae8f5234357308b9a638b",
    "CF_AI_GATEWAY_ID": "meathill",
    // 'auto' | 'openai' | 'gemini'。'auto'（推荐）按来源地区切：中国地区(CN/HK/TW/MO)走
    // OpenAI 兼容端点(MIMO)，其余走 Gemini；显式 'openai'/'gemini' 则强制锁定。
    // 两个 provider 的 secrets 都要备好：OPENAI_API_KEY/OPENAI_BASE_URL/OPENAI_MODEL 与 GEMINI_API_KEY。
    "AI_PROVIDER": "auto",
    "OPENAI_BASE_URL": "https://token-plan-sgp.xiaomimimo.com/v1",
    "OPENAI_MODEL": "mimo-v2.5"
  }
}
